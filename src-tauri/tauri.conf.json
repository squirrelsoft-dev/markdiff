{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "markdiff",
  "version": "0.1.0",
  "identifier": "com.sbeardsley.markdiff",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "markdiff",
        "width": 1280,
        "height": 840,
        "minWidth": 720,
        "minHeight": 480,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../scripts/markdiff": "markdiff"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SquirrelSoft LLC",
    "copyright": "Copyright © 2026 SquirrelSoft LLC",
    "category": "DeveloperTool",
    "shortDescription": "Compare two markdown documents.",
    "longDescription": "markdiff compares two markdown documents three ways: aligned source, unified source, and the rendered document with every edit marked in place. The side-by-side view is editable, so drafts can be pasted in and worked on directly.",
    "licenseFile": "../LICENSE",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
